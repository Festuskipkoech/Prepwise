# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Database 
POSTGRES_USER=jobsearchos
POSTGRES_PASSWORD=changeme
POSTGRES_DB=jobsearchos
DATABASE_URL=postgresql+asyncpg://jobsearchos:changeme@localhost:5432/jobsearchos

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=YOUR_PASS_HERE
REDIS_DB_AUTH=0
REDIS_DB_PUBSUB=1
REDIS_DB_CACHE=2
REDIS_DB_RATELIMIT=3

# Qdrant  
QDRANT_HOST=localhost
QDRANT_PORT=6333

# LLM
ANTHROPIC_API_KEY=sk-ant-...
LLM_SONNET_MODEL=claude-sonnet-4-6
LLM_HAIKU_MODEL=claude-haiku-4-5-20251001

# Embeddings
JINA_API_KEY=jina_...

# Job Search
SERP_API_KEY=...

# Auth
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30
BCRYPT_COST=12

# Profile
PROFILE_PATH=profile/master_profile.md